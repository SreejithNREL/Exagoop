#!/usr/bin/env bash
# exagoop-build-udf
# ─────────────────────────────────────────────────────────────────────────────
# Compiles a user-defined level-set .cpp into a shared library that ExaGOOP
# can load at runtime without recompilation.
#
# This script is generated by CMake at install time — the AMReX and cmake
# directory paths below are baked in automatically.
#
# Usage:
#   exagoop-build-udf <source.cpp> <output_dir> [extra cmake args...]
#
# Example:
#   exagoop-build-udf my_geometry.cpp ./run01
#   # produces: ./run01/udf_build/levelset_udf.so
#
# Then in your input file:
#   eb2.geom_type   = udf_cpp
#   eb2.udf_so_file = ./run01/udf_build/levelset_udf.so
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── Paths baked in by CMake at install time ───────────────────────────────────
EXAGOOP_CMAKE_DIR="@CMAKE_SOURCE_DIR@/CMake/udf_builder"
AMREX_DIR="@EXAGOOP_AMREX_DIR@"

# ── Argument parsing ──────────────────────────────────────────────────────────
if [ "$#" -lt 2 ]; then
    echo "Usage: exagoop-build-udf <source.cpp> <output_dir> [extra cmake args...]"
    echo ""
    echo "  source.cpp   — your level-set UDF source file"
    echo "  output_dir   — directory where udf_build/ will be created"
    echo ""
    echo "Templates are installed at:"
    echo "  @CMAKE_INSTALL_PREFIX@/share/exagoop/udf_templates/"
    exit 1
fi

UDF_SRC="$(realpath "$1")"
OUT_DIR="$(realpath "$2")"
shift 2
EXTRA_ARGS=("${@:-}")

# ── Validate ──────────────────────────────────────────────────────────────────
if [ ! -f "${UDF_SRC}" ]; then
    echo "[ExaGOOP] ERROR: source file not found: ${UDF_SRC}"
    exit 1
fi

BUILD_DIR="${OUT_DIR}/udf_build"
mkdir -p "${BUILD_DIR}"

echo "[ExaGOOP] Building UDF: ${UDF_SRC}"
echo "[ExaGOOP] Output dir : ${BUILD_DIR}"
echo ""

# ── Configure ─────────────────────────────────────────────────────────────────
cmake -S "${EXAGOOP_CMAKE_DIR}" \
      -B "${BUILD_DIR}"          \
      -DCMAKE_BUILD_TYPE=Release \
      -DUDF_SOURCE_FILE="${UDF_SRC}" \
      -DAMReX_DIR="${AMREX_DIR}"     

# ── Build ─────────────────────────────────────────────────────────────────────
cmake --build "${BUILD_DIR}" --parallel

DYLIB=$(ls "${BUILD_DIR}"/liblevelset_udf.* 2>/dev/null | head -1)
echo ""
echo "[ExaGOOP] Done. Add this to your input file:"
echo "    eb2.geom_type   = udf_cpp"
echo "    eb2.udf_so_file = ${DYLIB}"
