#!/bin/bash
# =============================================================================
# exagoop-build-udf — build a ExaGOOP level-set UDF shared library
#
# This script is generated by CMake from Tools/exagoop-build-udf.in.
# @EXAGOOP_UDF_BUILDER_DIR@ is substituted at install time with the
# path to CMake/udf_builder/.
#
# Usage:
#   exagoop-build-udf <udf_source.cpp> <output_dir>
#
# Example:
#   exagoop-build-udf Exec/my_case/circle.cpp Exec/my_case/udf_build
#
# Output:
#   <output_dir>/liblevelset_udf.so      (Linux)
#   <output_dir>/liblevelset_udf.dylib   (macOS)
#
# The resulting library is used in the input file as:
#   eb2.geom_type   = udf_cpp
#   eb2.udf_so_file = /absolute/path/to/output_dir/liblevelset_udf.dylib
# =============================================================================

set -e

# ---------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------
if [ "$#" -lt 2 ]; then
    echo ""
    echo "  Usage: exagoop-build-udf <udf_source.cpp> <output_dir>"
    echo ""
    echo "  Example:"
    echo "    exagoop-build-udf Exec/my_case/circle.cpp Exec/my_case/udf_build"
    echo ""
    echo "  The UDF must export:"
    echo "    extern \"C\" double levelset_phi(double x, double y, double z);"
    echo ""
    echo "  Convention:"
    echo "    phi < 0  inside obstacle"
    echo "    phi > 0  outside obstacle"
    echo "    phi = 0  on surface"
    echo ""
    exit 1
fi

UDF_SRC="$(cd "$(dirname "$1")" && pwd)/$(basename "$1")"
OUT_DIR="$(mkdir -p "$2" && cd "$2" && pwd)"

if [ ! -f "${UDF_SRC}" ]; then
    echo "Error: source file not found: ${UDF_SRC}"
    exit 1
fi

# ---------------------------------------------------------------
# CMake satellite project location (substituted at install time)
# ---------------------------------------------------------------
UDF_BUILDER_DIR="@EXAGOOP_UDF_BUILDER_DIR@"

if [ ! -f "${UDF_BUILDER_DIR}/CMakeLists.txt" ]; then
    echo "Error: UDF builder CMakeLists.txt not found at: ${UDF_BUILDER_DIR}"
    echo "       Re-install ExaGOOP or check your installation."
    exit 1
fi

# ---------------------------------------------------------------
# Build in a temporary directory
# ---------------------------------------------------------------
BUILD_TMP="$(mktemp -d)"
trap 'rm -rf "${BUILD_TMP}"' EXIT

echo ""
echo "  Building UDF: ${UDF_SRC}"
echo "  Output dir  : ${OUT_DIR}"
echo ""

cmake -S "${UDF_BUILDER_DIR}" \
      -B "${BUILD_TMP}"       \
      -DUDF_SRC="${UDF_SRC}"  \
      -DOUT_DIR="${OUT_DIR}"  \
      -DCMAKE_BUILD_TYPE=Release \
      --no-warn-unused-cli \
      -Wno-dev

cmake --build "${BUILD_TMP}" --config Release

echo ""
echo "  Done. Add to your input file:"
echo "    eb2.geom_type   = udf_cpp"
if [[ "$(uname)" == "Darwin" ]]; then
    echo "    eb2.udf_so_file = ${OUT_DIR}/liblevelset_udf.dylib"
else
    echo "    eb2.udf_so_file = ${OUT_DIR}/liblevelset_udf.so"
fi
echo ""
